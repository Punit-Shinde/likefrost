---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Ecosystem Modules" description="Explore the Likefrost snowflake-style ecosystem.">
  <div style="padding: 2rem; max-width: 1000px; margin: 0 auto;">
    <h1 style="text-align: center; margin-bottom: 3rem;">The Likefrost Ecosystem</h1>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
      <div style="border: 1px solid #e2e8f0; padding: 2rem; border-radius: 12px; background: var(--card-bg);">
        <h2 style="color: var(--primary);">Social & Bio</h2>
        <ul style="color: #475569; padding-left: 1.2rem;">
          <li><strong>Likefrost Social:</strong> Content engine for creating, scheduling, and publishing posts.</li>
          <li><strong>Likefrost Bio:</strong> Link‑in‑bio hub with UPI‑native payment flows.</li>
        </ul>
      </div>
      <div style="border: 1px solid #e2e8f0; padding: 2rem; border-radius: 12px; background: var(--card-bg);">
        <h2 style="color: var(--primary);">Engagement & Monetization</h2>
        <ul style="color: #475569; padding-left: 1.2rem;">
          <li><strong>Likefrost DM:</strong> Automated comment‑to‑DM conversion pipeline.</li>
          <li><strong>Likefrost Club:</strong> Subscription monetization layer for exclusive communities.</li>
        </ul>
      </div>
      <div style="border: 1px solid #e2e8f0; padding: 2rem; border-radius: 12px; background: var(--card-bg);">
        <h2 style="color: var(--primary);">Business & Finance</h2>
        <ul style="color: #475569; padding-left: 1.2rem;">
          <li><strong>Likefrost Pitch:</strong> Media kit builder with rate calculator.</li>
          <li><strong>Likefrost Safe:</strong> Escrow + contract engine to secure payments.</li>
          <li><strong>Likefrost Ledger:</strong> Income/expense tracker aligned with freelancer tax codes.</li>
        </ul>
      </div>
    </div>
  </div>
</MainLayout>
