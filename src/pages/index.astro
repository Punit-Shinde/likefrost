---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import TrustBar from '../components/TrustBar.astro';
import ModuleGrid from '../components/ModuleGrid.astro';
import FeatureHighlight from '../components/FeatureHighlight.astro';
import CtaSection from '../components/CtaSection.astro';
---

<MainLayout>
  <Hero />
  <TrustBar />
  <Marquee />
  <ModuleGrid />
  
  <FeatureHighlight 
    title="Mobile-First Workflows" 
    description="Optimized for smartphones with chunked uploads for unstable 5G grids. Keep creating without interruptions." 
    imageSrc="/images/mobile.png" 
    imageAlt="Mobile Workflow" 
  />
  
  <FeatureHighlight 
    title="Fair Monetization & Security" 
    description="UPI and domestic tax compliance (Section 44ADA) eliminate FX fees and onboarding friction. Backed by Escrow and contracts to protect freelancers from defaults." 
    imageSrc="/images/monetization.png" 
    imageAlt="Monetization and Security" 
    reverse={true}
  />
  
  <CtaSection />
</MainLayout>
