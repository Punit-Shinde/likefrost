---
import { type CollectionEntry, getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<MainLayout title={post.data.title} description={post.data.description}>
  <article style="padding: 2rem; max-width: 800px; margin: 0 auto;">
    <h1>{post.data.title}</h1>
    <p style="color: #666;">By {post.data.author} on {post.data.pubDate.toLocaleDateString()}</p>
    <hr style="margin: 2rem 0; border: none; border-top: 1px solid #eaeaea;" />
    <div class="content">
      <Content />
    </div>
  </article>
</MainLayout>
