---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Likefrost Documentation" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO title={title} description={description} />
  </head>
  <body>
    <Header />
    <div style="display: flex; max-width: 1200px; margin: 0 auto;">
      <aside style="width: 250px; padding: 1rem; border-right: 1px solid #eaeaea;">
        <nav>
          <ul style="list-style: none; padding: 0;">
            <li><a href="/docs" style="text-decoration: none; color: #333;">Docs Home</a></li>
          </ul>
        </nav>
      </aside>
      <main style="flex: 1; padding: 1rem;">
        <slot />
      </main>
    </div>
    <Footer />
  </body>
</html>

<style>
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
  }
</style>
