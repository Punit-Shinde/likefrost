---
interface Props {
  competitorName: string;
  features: Array<{ name: string; us: boolean; them: boolean }>;
}

const { competitorName, features } = Astro.props;
---

<table style="width: 100%; border-collapse: collapse; margin: 2rem 0;">
  <thead>
    <tr>
      <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Feature</th>
      <th style="border: 1px solid #ddd; padding: 8px; text-align: center;">Us</th>
      <th style="border: 1px solid #ddd; padding: 8px; text-align: center;">{competitorName}</th>
    </tr>
  </thead>
  <tbody>
    {features.map(feature => (
      <tr>
        <td style="border: 1px solid #ddd; padding: 8px;">{feature.name}</td>
        <td style="border: 1px solid #ddd; padding: 8px; text-align: center;">{feature.us ? '✅' : '❌'}</td>
        <td style="border: 1px solid #ddd; padding: 8px; text-align: center;">{feature.them ? '✅' : '❌'}</td>
      </tr>
    ))}
  </tbody>
</table>
